# Git & IDE
.git
.github
.idea
.vscode
.cursor
.claude
.agents
.cursorignore
*.md

# Local Docker Compose (not used on Render)
docker-compose.yml

# Dependencies (installed in image build stages)
/node_modules
/vendor

# Build output (generated in image)
/public/build
/public/hot

# Environment & secrets
.env
.env.*
!.env.example

# Storage runtime (ephemeral on Render unless a disk is attached)
/storage/*.key
/storage/pail
/storage/logs/*
/storage/framework/cache/*
/storage/framework/sessions/*
/storage/framework/views/*
/storage/app/public/*
/storage/app/restore-tmp-*

# Tests & dev tools
/tests
/phpunit.xml
/.phpunit.cache
/phpunit.result.cache
/composer.phar
/dist
/installer

# OS
.DS_Store
Thumbs.db
*.log
