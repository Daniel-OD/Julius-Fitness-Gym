# Julius Fitness Gym — Railway environment reference
# Set these in Railway → your service → Variables (or reference from another service).
# Railway injects PORT and DATABASE_URL when PostgreSQL is linked — do not hardcode PORT.

APP_NAME="Julius Fitness Gym"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-service.up.railway.app

APP_LOCALE=ro
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=info

# PostgreSQL (link database service; prefer DATABASE_URL reference)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=railway
DB_USERNAME=postgres
DB_PASSWORD=
# DATABASE_URL=  # set via Variable Reference: ${{ Postgres.DATABASE_URL }}

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=file

# Resend — set RESEND_API_KEY in Railway Variables (mark as secret)
MAIL_MAILER=resend
RESEND_API_KEY=
MAIL_FROM_ADDRESS="noreply@your-verified-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
