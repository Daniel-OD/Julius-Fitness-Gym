# Julius Fitness Gym — Render environment reference
# Set these in the Render Dashboard (Environment tab) or via render.yaml.
# Render injects RENDER=true and PORT automatically — do not set PORT manually.

APP_NAME="Julius Fitness Gym"
APP_ENV=production
APP_DEBUG=false
APP_KEY=
APP_URL=https://your-service.onrender.com

APP_LOCALE=ro
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stderr
LOG_LEVEL=info

# PostgreSQL (Render managed database)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=julius_gym
DB_USERNAME=julius
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@julius-gym.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
