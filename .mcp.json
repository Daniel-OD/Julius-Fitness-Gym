{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "sentry": {
            "type": "http",
            "url": "https://mcp.sentry.dev/mcp?utm_source=plugin"
        },
        "postman": {
            "type": "http",
            "url": "https://mcp.postman.com/mcp",
            "headers": {
                "Authorization": "Bearer ${POSTMAN_API_KEY}"
            }
        }
    }
}