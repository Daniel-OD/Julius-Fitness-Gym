#!/usr/bin/env bash
set -euo pipefail

APP_DIR="${HOME}/Herd/julius-fitness-gym"
URL="http://julius-fitness-gym.test/admin"

notify() {
    osascript -e "display alert \"Julius Fitness Gym\" message \"$1\"" 2>/dev/null || echo "$1"
}

if [[ ! -d "${APP_DIR}" ]]; then
    notify "Copiază proiectul în ~/Herd/julius-fitness-gym și rulează install.sh din DMG."
    exit 1
fi

if [[ ! -f "${APP_DIR}/storage/app/.install-complete" ]]; then
    notify "Prima rulare: se configurează aplicația (1-3 minute)..."
    /bin/bash "${APP_DIR}/install.sh" || {
        notify "Instalarea a eșuat. Rulează install.sh din Terminal pentru detalii."
        exit 1
    }
fi

open "${URL}"
